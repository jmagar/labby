[
  {
    "service": "acp",
    "env_var": "LAB_ACP_DB",
    "required": false,
    "secret": false,
    "description": "Path to ACP SQLite database",
    "example": "~/.lab/acp.db",
    "default_port": null
  },
  {
    "service": "acp",
    "env_var": "LAB_ACP_HMAC_SECRET",
    "required": false,
    "secret": true,
    "description": "HMAC key for permission outcome signing; auto-generated if absent",
    "example": "<lab_acp_hmac_secret>",
    "default_port": null
  }
]
