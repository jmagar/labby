# TODO: pin by digest (FROM ubuntu:25.10@sha256:...) for reproducible builds —
#       floating tag resolves a fresh image per build.
FROM ubuntu:25.10
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates curl gnupg \
 && mkdir -p /etc/apt/keyrings \
 && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
    | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_24.x nodistro main" \
    > /etc/apt/sources.list.d/nodesource.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends nodejs zsh \
 && rm -rf /var/lib/apt/lists/*

# Pre-install ACP adapters at known exact versions so each session spawn skips
# the npx download/cache check and uses a deterministic binary. All versions
# are pinned exact (no caret/tilde) — npm install acts like npm ci against
# a fixed manifest. The claude-agent-sdk version determines which Claude Code
# binary ships and which credentials.json format it accepts; claude-agent-acp
# pins its transitive SDK with `=`, so the overrides entry is required to hold
# the bundled Claude Code binary forward to match the host credential format.
#
# UPGRADE PROCEDURE (bump adapter + SDK together):
#   1. Update all version strings in config/acp-adapters.package.json to the
#      new exact versions. Always bump claude-agent-acp and claude-agent-sdk
#      together — the overrides entry must match the direct dep.
#   2. docker build . -f config/Dockerfile.fast --no-cache -t labby:test
#   3. docker run --rm labby:test claude --version  # verify no SIGILL
#   4. Commit config/acp-adapters.package.json + Dockerfile.fast together.
COPY config/acp-adapters.package.json /opt/acp-adapters/package.json
RUN cd /opt/acp-adapters \
 && npm install --omit=dev --no-audit --no-fund \
 && ln -sf /opt/acp-adapters/node_modules/.bin/claude /usr/local/bin/claude \
 && ln -sf /opt/acp-adapters/node_modules/.bin/claude-agent-acp /usr/local/bin/claude-agent-acp \
 && ln -sf /opt/acp-adapters/node_modules/.bin/codex /usr/local/bin/codex \
 && ln -sf /opt/acp-adapters/node_modules/.bin/codex-acp /usr/local/bin/codex-acp \
 && ln -sf /opt/acp-adapters/node_modules/.bin/gemini /usr/local/bin/gemini \
 && npm cache clean --force

# Python MCP servers commonly use `uvx` as their stdio launcher. Install uv
# into PATH for gateway child processes.
#
# Reproducibility: the astral.sh installer pins a version when UV_VERSION is set
# (it fetches that exact release instead of "latest"). UV_VERSION is currently
# empty, so this tracks the latest uv at build time.
# TODO: pin uv by setting UV_VERSION to a verified release tag (e.g. "0.x.y")
#       so the image is reproducible across builds.
ARG UV_VERSION=""
RUN curl -LsSf https://astral.sh/uv/install.sh \
    | env UV_INSTALL_DIR=/usr/local/bin UV_VERSION="${UV_VERSION}" sh \
 && uv --version \
 && uvx --version

RUN mkdir -p /home/lab/.lab /home/lab/.config/lab /home/lab/.local/state/lab /home/lab/.local/share/lab && chown -R 1000:1000 /home/lab
COPY bin/labby /usr/local/bin/labby
RUN chmod +x /usr/local/bin/labby
ENV HOME=/home/lab
USER 1000:1000
WORKDIR /home/lab
EXPOSE 8765

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -sf http://localhost:8765/health || exit 1

ENTRYPOINT ["/usr/local/bin/labby"]
CMD ["serve"]
