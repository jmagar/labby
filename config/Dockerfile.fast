FROM ubuntu:25.10
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates curl gnupg \
 && mkdir -p /etc/apt/keyrings \
 && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
    | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_24.x nodistro main" \
    > /etc/apt/sources.list.d/nodesource.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends nodejs zsh \
 && rm -rf /var/lib/apt/lists/*

# Pre-install ACP adapters at known versions so each session spawn skips the
# npx download/cache check and uses a deterministic binary. The claude-agent-sdk
# version determines which Claude Code binary ships, which determines which
# credentials.json formats it accepts. claude-agent-acp pins its SDK with `=`,
# so we override the nested install via package.json overrides to float the
# bundled Claude Code binary forward — matching newer host credential formats
# (host Claude Code 2.1.132 + pinned SDK 0.2.126 → SIGILL).
RUN mkdir -p /opt/acp-adapters \
 && cd /opt/acp-adapters \
 && cat > package.json <<'EOF'
{
  "name": "lab-acp-adapters",
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.32.0",
    "@anthropic-ai/claude-code": "2.1.132",
    "@anthropic-ai/claude-agent-sdk": "^0.2.131",
    "@openai/codex": "0.130.0",
    "@zed-industries/codex-acp": "0.12.0",
    "@google/gemini-cli": "0.40.0"
  },
  "overrides": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.131"
  }
}
EOF
RUN cd /opt/acp-adapters \
 && npm install --omit=dev --no-audit --no-fund \
 && ln -sf /opt/acp-adapters/node_modules/.bin/claude /usr/local/bin/claude \
 && ln -sf /opt/acp-adapters/node_modules/.bin/claude-agent-acp /usr/local/bin/claude-agent-acp \
 && ln -sf /opt/acp-adapters/node_modules/.bin/codex /usr/local/bin/codex \
 && ln -sf /opt/acp-adapters/node_modules/.bin/codex-acp /usr/local/bin/codex-acp \
 && ln -sf /opt/acp-adapters/node_modules/.bin/gemini /usr/local/bin/gemini \
 && npm cache clean --force

# Python MCP servers commonly use `uvx` as their stdio launcher. Install uv
# into PATH for gateway child processes.
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh \
 && uv --version \
 && uvx --version

RUN mkdir -p /home/lab/.lab /home/lab/.config/lab /home/lab/.local/state/lab /home/lab/.local/share/lab && chown -R 1000:1000 /home/lab
COPY bin/labby /usr/local/bin/labby
RUN chmod +x /usr/local/bin/labby
ENV HOME=/home/lab
USER 1000:1000
WORKDIR /home/lab
EXPOSE 8765

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -sf http://localhost:8765/health || exit 1

ENTRYPOINT ["/usr/local/bin/labby"]
CMD ["serve"]
