# ─── Docker deployment ────────────────────────────────────────────────────────
# Remap the host-side port without editing docker-compose.yml.
# LAB_HOST_PORT=8765

# Override the tracing filter set in config/config.toml.
# RUST_LOG=lab=debug,warn
