#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT"

target="plugins/dozzle"

failures=0

if [[ ! -d "$target" ]]; then
  if [[ "${LAB_ALLOW_MISSING_DOZZLE:-0}" != "1" ]]; then
    printf 'dozzle skill check failed: %s is not present in this checkout\n' "$target" >&2
    printf 'set LAB_ALLOW_MISSING_DOZZLE=1 only when the retired Dozzle plugin checkout is intentionally absent\n' >&2
    exit 1
  fi
  printf 'dozzle skill check skipped: %s is not present in this checkout\n' "$target"
  exit 0
fi

check_absent() {
  local description="$1"
  local pattern="$2"

  if rg -n -S -- "$pattern" "$target"; then
    printf 'dozzle skill check failed: %s\n  pattern: %s\n' "$description" "$pattern" >&2
    failures=$((failures + 1))
  fi
}

check_absent "stale Lab MCP dispatch guidance" 'mcp__lab__dozzle.*Dispatch'
check_absent "stale lab dozzle CLI command guidance" 'lab dozzle --help|lab dozzle <action> --help'
check_absent "stale labby dozzle CLI command guidance" 'labby --json dozzle'
check_absent "stale Lab homelab-control-plane description" 'homelab control plane|Lab.s Dozzle integration'
check_absent "stale MCP/CLI reference files" 'references/(mcp|cli)\.md'
check_absent "unsafe cookie header in curl argv" 'curl.*-H[[:space:]]*["'\'']Cookie:'

mcp_file="$target/.mcp.json"
if [[ ! -e "$mcp_file" ]]; then
  printf 'dozzle skill check failed: native Dozzle MCP config is missing\n  file: %s\n' "$mcp_file" >&2
  failures=$((failures + 1))
elif jq -e '
  .mcpServers.dozzle.type == "http"
  and .mcpServers.dozzle.url == "${userConfig.dozzle_mcp_url}"
  and (.mcpServers.dozzle.command | not)
  and (.mcpServers.dozzle.args | not)
' "$mcp_file" >/dev/null; then
  :
else
  printf 'dozzle skill check failed: MCP config must point at Dozzle native HTTP /api/mcp, not Lab command wrapping\n  file: %s\n' "$mcp_file" >&2
  failures=$((failures + 1))
fi

if (( failures > 0 )); then
  exit 1
fi

printf 'dozzle skill check passed\n'
