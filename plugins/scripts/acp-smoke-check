#!/usr/bin/env bash
# Smoke-check the Docker-hosted ACP bridge and Codex ACP launch policy.
#
# Default behavior:
#   1. verify the mounted Docker ACP provider config disables Codex's inner sandbox
#   2. verify /v1/acp/provider reports codex-acp as available
#   3. create a Codex ACP session
#   4. send a small prompt asking the provider to run `pwd`
#   5. stream SSE briefly and print the first relevant ACP events
#
# Use --provider-only for a fast, no-session config/health check.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BASE="${LAB_ACP_BASE:-${LAB_API_BASE:-http://127.0.0.1:${LAB_MCP_HTTP_PORT:-8765}/v1}/acp}"
PROVIDER="${ACP_SMOKE_PROVIDER:-codex-acp}"
CWD_VALUE="${ACP_SMOKE_CWD:-/workspace/lab}"
TIMEOUT_SECONDS="${ACP_SMOKE_TIMEOUT_SECONDS:-60}"
PROMPT="${ACP_SMOKE_PROMPT:-Run pwd in the terminal, then reply with only the working directory.}"
PROVIDER_ONLY=0
SESSION_ID=""

usage() {
    sed -n '2,12p' "$0" | sed 's/^# \?//'
    printf '\nOptions:\n'
    printf '  --provider-only   only check mounted config and /provider health\n'
    printf '  -h, --help        show this help\n'
}

for arg in "$@"; do
    case "$arg" in
        --provider-only) PROVIDER_ONLY=1 ;;
        -h|--help) usage; exit 0 ;;
        *) echo "error: unknown argument: $arg" >&2; usage >&2; exit 2 ;;
    esac
done

ENV_FILE="${LAB_ENV_FILE:-$HOME/.lab/.env}"
if [ -f "$ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
fi

TOKEN="${LAB_MCP_HTTP_TOKEN:-${NEXT_PUBLIC_API_TOKEN:-${LAB_API_TOKEN:-}}}"
AUTH_ARGS=()
if [ -n "${TOKEN:-}" ]; then
    AUTH_ARGS=(-H "Authorization: Bearer $TOKEN")
fi

json_get() {
    local path="$1"
    curl -fsS "${AUTH_ARGS[@]}" "$BASE$path"
}

json_post() {
    local path="$1" payload="$2"
    curl -fsS "${AUTH_ARGS[@]}" -H 'Content-Type: application/json' -X POST --data "$payload" "$BASE$path"
}

json_field() {
    python3 -c 'import json,sys; data=json.load(sys.stdin); exec(sys.argv[1])' "$1"
}

print_step() {
    printf '==> %s\n' "$*"
}

cleanup_session() {
    if [ -z "$SESSION_ID" ] || [ "${ACP_SMOKE_KEEP_SESSION:-0}" = "1" ]; then
        return 0
    fi

    json_post "" "$(python3 - <<PY
import json
print(json.dumps({
    "action": "session.close",
    "params": {
        "session_id": "$SESSION_ID",
        "confirm": True,
    },
}))
PY
)" >/dev/null 2>&1 || true
}

trap cleanup_session EXIT

check_mounted_config() {
    if ! docker compose -f "$ROOT/docker-compose.yml" -f "$ROOT/docker-compose.dev.yml" ps -q labby-master >/dev/null 2>&1; then
        echo "warn: docker compose service labby-master is not available; skipping mounted config check" >&2
        return 0
    fi

    local container
    container="$(docker compose -f "$ROOT/docker-compose.yml" -f "$ROOT/docker-compose.dev.yml" ps -q labby-master)"
    if [ -z "$container" ]; then
        echo "warn: labby-master is not running; skipping mounted config check" >&2
        return 0
    fi

    docker exec "$container" python3 - <<'PY'
import json
from pathlib import Path

provider_path = Path("/home/lab/.lab/acp-providers.json")
codex_home_config = Path("/home/lab/.lab/acp/codex-home/config.toml")

providers = json.loads(provider_path.read_text())
codex = next((p for p in providers if p.get("id") == "codex-acp"), None)
if codex is None:
    raise SystemExit("codex-acp missing from mounted provider config")

args = codex.get("args") or []
if 'sandbox_mode="danger-full-access"' not in args:
    raise SystemExit("codex-acp provider args do not include sandbox_mode=\"danger-full-access\"")

if codex_home_config.exists() and 'sandbox_mode = "danger-full-access"' not in codex_home_config.read_text():
    raise SystemExit("Codex CODEX_HOME config.toml does not set sandbox_mode = \"danger-full-access\"")

print("mounted provider config OK")
PY
}

print_step "checking mounted Docker ACP config"
check_mounted_config

print_step "checking ACP provider health at $BASE/provider"
provider_json="$(json_get /provider)"
printf '%s\n' "$provider_json" | json_field '
providers = data.get("providers") or [data.get("provider") or {}]
provider = next((p for p in providers if (p.get("name") or p.get("provider")) == "'"$PROVIDER"'"), None)
if provider is None:
    raise SystemExit("'"$PROVIDER"' missing from provider health response")
available = provider.get("available", provider.get("ready", False))
message = provider.get("error") or provider.get("message") or ""
if not available:
    raise SystemExit("'"$PROVIDER"' unavailable: " + message)
print("'"$PROVIDER"' provider health OK")
'

if [ "$PROVIDER_ONLY" -eq 1 ]; then
    exit 0
fi

print_step "creating ACP session for $PROVIDER"
create_payload="$(python3 - <<PY
import json
print(json.dumps({
    "provider": "$PROVIDER",
    "cwd": "$CWD_VALUE",
    "title": "ACP smoke check",
}))
PY
)"
session_json="$(json_post /sessions "$create_payload")"
SESSION_ID="$(printf '%s\n' "$session_json" | json_field 'session = data.get("session") or data; print(session["id"])')"
printf 'session: %s\n' "$SESSION_ID"

print_step "sending smoke prompt"
prompt_payload="$(python3 - <<PY
import json
print(json.dumps({"prompt": "$PROMPT"}))
PY
)"
json_post "/sessions/$SESSION_ID/prompt" "$prompt_payload" >/dev/null

print_step "streaming ACP events for up to ${TIMEOUT_SECONDS}s"
ticket_json="$(json_post "/sessions/$SESSION_ID/subscribe_ticket" '{}')"
ticket="$(printf '%s\n' "$ticket_json" | json_field 'print(data["ticket"])')"

events_url="$BASE/sessions/$SESSION_ID/events?since=0&ticket=$ticket"
set +e
ACP_EXPECTED_CWD="$CWD_VALUE" timeout "$TIMEOUT_SECONDS" curl -fsSN "${AUTH_ARGS[@]}" "$events_url" 2>/dev/null \
    | python3 -c '
import json
import os
import sys

seen = 0
message = ""
provider_error = ""
terminal_state = ""
expected = os.environ.get("ACP_EXPECTED_CWD", "")

for line in sys.stdin:
    if not line.startswith("data:"):
        continue
    payload = line[5:].strip()
    if not payload:
        continue
    try:
        event = json.loads(payload)
    except json.JSONDecodeError:
        continue
    kind = event.get("kind") or event.get("type") or "event"
    text = event.get("text") or event.get("title") or event.get("status") or ""
    raw = event.get("raw") if isinstance(event.get("raw"), dict) else {}
    raw_type = raw.get("type") or ""
    raw_text = raw.get("text") or raw.get("message") or raw.get("title") or ""
    if kind == "message_chunk":
        message += text
    if kind == "provider_info" and raw_type in {"provider_error", "runtime_exit_without_stop_reason"}:
        provider_error = raw_text or text or raw_type
    if kind == "session_update":
        terminal_state = event.get("state") or text
    seq = event.get("seq", "?")
    print(f"{seq}: {kind}: {text}")
    seen += 1
    if expected and expected in message:
        break
    if provider_error or terminal_state in {"failed", "Failed"}:
        break
    if kind in {"session_update", "message_chunk", "tool_call_update", "provider_info"} and seen >= 20:
        break

if provider_error:
    print(f"ACP smoke failed: provider error: {provider_error}", file=sys.stderr)
    raise SystemExit(1)
if expected and expected not in message:
    print(
        f"ACP smoke failed: expected assistant output containing {expected!r}; got {message!r}",
        file=sys.stderr,
    )
    raise SystemExit(1)
'
stream_statuses=("${PIPESTATUS[@]}")
set -e
if [ "${stream_statuses[1]}" -ne 0 ]; then
    exit "${stream_statuses[1]}"
fi
if [ "${stream_statuses[0]}" -ne 0 ] && [ "${stream_statuses[0]}" -ne 124 ] && [ "${stream_statuses[0]}" -ne 141 ]; then
    echo "ACP smoke failed: event stream exited with status ${stream_statuses[0]}" >&2
    exit "${stream_statuses[0]}"
fi

print_step "ACP smoke prompt completed"
