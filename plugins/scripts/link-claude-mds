#!/usr/bin/env bash
# bin/link-claude-mds — make CLAUDE.md the source of truth for repo memory files
#
# Finds every CLAUDE.md in the target repo and replaces sibling AGENTS.md and
# GEMINI.md with symlinks that point to CLAUDE.md.
#
# Usage:  bin/link-claude-mds         # scan the current repo
#         bin/link-claude-mds /path   # scan a specific repo root

set -euo pipefail

ROOT="${1:-$(pwd)}"

if [ ! -d "$ROOT" ]; then
    echo "error: not a directory: $ROOT" >&2
    exit 1
fi

count=0

while IFS= read -r claude; do
    dir="$(dirname "$claude")"
    rel_dir="${dir#"$ROOT"/}"
    if [ "$dir" = "$ROOT" ]; then
        rel_dir="."
    fi

    ln -sfn "CLAUDE.md" "$dir/AGENTS.md"
    ln -sfn "CLAUDE.md" "$dir/GEMINI.md"

    printf 'linked %s\n' "$rel_dir"
    count=$((count + 1))
done < <(find "$ROOT" -type f -name 'CLAUDE.md' | sort)

printf 'updated %d CLAUDE.md directories\n' "$count"
