#!/usr/bin/env bash
# Installed by broadcastr-install-hooks. Do not edit in-place.
set -uo pipefail
. "$(dirname "$0")/_lib.sh"
bcr_hook_init post-commit

SENTINEL="$HOOK_DIR/$BCR_MERGE_SENTINEL_BASENAME"
SHA="$(git rev-parse HEAD 2>/dev/null || echo unknown)"
FILES="$(git diff --name-only HEAD~1 HEAD 2>/dev/null | wc -l | tr -d ' ')"
SUBJECT="$(git log -1 --pretty=%s 2>/dev/null || echo '?')"

dedup=0
if [ -f "$SENTINEL" ]; then
  age=$(( $(date +%s) - $(stat -c %Y "$SENTINEL" 2>/dev/null || stat -f %m "$SENTINEL" 2>/dev/null || echo 0) ))
  last_sha="$(cat "$SENTINEL" 2>/dev/null || true)"
  if [ "$age" -le 2 ] && [ "$last_sha" = "$SHA" ]; then
    dedup=1
  fi
fi

if [ "$dedup" = "0" ]; then
  "$PLUGIN_ROOT/scripts/emit.sh" \
    --category commit --tier info --source git-hook \
    --branch "$BRANCH" \
    --summary "commit ${SHA:0:7}: $SUBJECT" \
    --data "{\"sha\":\"$SHA\",\"files_changed\":$FILES,\"subtype\":\"commit\"}"
fi

bcr_chain_prev "$@"
exit 0
