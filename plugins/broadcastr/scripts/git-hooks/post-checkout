#!/usr/bin/env bash
set -uo pipefail
. "$(dirname "$0")/_lib.sh"
bcr_hook_init post-checkout

PREV_REF="${1:-?}"
NEW_REF="${2:-?}"
FLAG="${3:-?}"

# Only emit for branch checkouts (FLAG=1). File-level checkouts (FLAG=0)
# fire on every `git checkout <file>` and are pure noise for cross-session
# awareness.
if [ "$FLAG" = "1" ]; then
  NAME="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
  if command -v jq >/dev/null 2>&1; then
    DATA="$(jq -nc --arg prev "$PREV_REF" --arg new "$NEW_REF" --arg name "$NAME" \
      '{prev:$prev, new:$new, branch:$name}')"
  else
    DATA='{"prev":"?","new":"?"}'
  fi
  "$PLUGIN_ROOT/scripts/emit.sh" \
    --category branch --tier info --source git-hook \
    --summary "checkout: $NAME" \
    --data "$DATA"
fi

bcr_chain_prev "$@"
exit 0
