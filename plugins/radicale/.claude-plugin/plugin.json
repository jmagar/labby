{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "radicale",
  "description": "CalDAV and CardDAV workflow skills for Radicale.",
  "author": {
    "name": "Jacob Magar",
    "email": "jmagar@users.noreply.github.com"
  },
  "repository": "https://github.com/jmagar/claude-homelab",
  "homepage": "https://github.com/jmagar/claude-homelab",
  "license": "MIT",
  "keywords": [
    "radicale",
    "caldav",
    "carddav",
    "calendar",
    "contacts"
  ],
  "userConfig": {
    "radicale_url": {
      "type": "string",
      "title": "Radicale URL",
      "description": "Base URL of the Radicale CalDAV/CardDAV server, including scheme.",
      "required": true
    },
    "radicale_username": {
      "type": "string",
      "title": "Username",
      "description": "Radicale username.",
      "required": true
    },
    "radicale_password": {
      "type": "string",
      "title": "Password",
      "description": "Radicale password.",
      "sensitive": true,
      "required": true
    }
  }
}
