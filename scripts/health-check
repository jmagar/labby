#!/usr/bin/env bash
# bin/health-check — ping every configured service in .env
#
# Reads ~/workspace/lab/.env and probes each service whose URL is set.
# Prints a one-line pass/fail per service with HTTP status + latency.
#
# Usage:  bin/health-check                # checks all configured services
#         bin/health-check radarr         # quiet solo check
#         bin/health-check radarr plex    # check only specified
#         bin/health-check -v             # verbose (show curl errors + body)

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ENV_FILE="${LAB_ENV_FILE:-$ROOT/.env}"

if [ ! -f "$ENV_FILE" ]; then
    echo "error: $ENV_FILE not found" >&2
    exit 1
fi

# Load env (allow leading "export", quoted values, ignore comments)
set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

VERBOSE=0
SELECTED=()
for arg in "$@"; do
    case "$arg" in
        -v|--verbose) VERBOSE=1 ;;
        -h|--help)
            sed -n '2,9p' "$0" | sed 's/^# \?//'
            exit 0 ;;
        *) SELECTED+=("$arg") ;;
    esac
done

SOLO_MODE=0
if [ ${#SELECTED[@]} -eq 1 ]; then
    SOLO_MODE=1
fi

# Colors (only if stdout is a tty)
if [ -t 1 ]; then
    G='\033[32m'; R='\033[31m'; Y='\033[33m'; D='\033[2m'; N='\033[0m'
else
    G=''; R=''; Y=''; D=''; N=''
fi

PASS=0
FAIL=0
SKIP=0
RESULT_DIR=$(mktemp -d)
RESULT_FILES=()
PIDS=()

cleanup() {
    rm -rf "$RESULT_DIR"
}
trap cleanup EXIT

should_probe() {
    local name="$1"
    if [ ${#SELECTED[@]} -eq 0 ]; then
        return 0
    fi

    local s
    for s in "${SELECTED[@]}"; do
        if [ "$s" = "$name" ]; then
            return 0
        fi
    done

    return 1
}

# probe_to_file OUTFILE SERVICE URL [curl_args...]
#   writes result metadata + rendered output to OUTFILE
probe_to_file() {
    local outfile="$1" name="$2" url="$3"; shift 3
    if [ -z "${url:-}" ]; then
        {
            printf '__RESULT__:skip\n'
            printf "  ${Y}skip${N}  %-14s ${D}(not configured)${N}\n" "$name"
        } > "$outfile"
        return 0
    fi
    local start http body code
    start=$(date +%s%3N 2>/dev/null || python3 -c 'import time;print(int(time.time()*1000))')
    body=$(mktemp)
    http=$(curl -ksS -o "$body" -w '%{http_code}' --max-time 8 "$@" "$url" 2>&1) || code=$?
    local end ms
    end=$(date +%s%3N 2>/dev/null || python3 -c 'import time;print(int(time.time()*1000))')
    ms=$((end - start))
    if [ "${code:-0}" != 0 ]; then
        {
            printf '__RESULT__:fail\n'
            printf "  ${R}FAIL${N}  %-14s ${D}%s${N}\n" "$name" "$http"
            if [ $VERBOSE -eq 1 ]; then
                sed 's/^/        /' "$body"
            fi
        } > "$outfile"
    elif [ "$http" -ge 200 ] && [ "$http" -lt 400 ]; then
        {
            printf '__RESULT__:pass\n'
            printf "  ${G} ok ${N}  %-14s ${D}%3d  %4dms${N}\n" "$name" "$http" "$ms"
        } > "$outfile"
    else
        {
            printf '__RESULT__:fail\n'
            printf "  ${R}FAIL${N}  %-14s ${D}%3d  %4dms${N}\n" "$name" "$http" "$ms"
            if [ $VERBOSE -eq 1 ]; then
                sed 's/^/        /' "$body"
            fi
        } > "$outfile"
    fi
    rm -f "$body"
}

launch_probe() {
    local name="$1" url="$2"; shift 2
    if ! should_probe "$name"; then
        return 0
    fi

    local outfile="$RESULT_DIR/$(printf '%03d' "${#RESULT_FILES[@]}").out"
    RESULT_FILES+=("$outfile")
    probe_to_file "$outfile" "$name" "$url" "$@" &
    PIDS+=("$!")
}

collect_results() {
    local pid outfile result

    for pid in "${PIDS[@]}"; do
        wait "$pid"
    done

    for outfile in "${RESULT_FILES[@]}"; do
        result=$(sed -n '1s/^__RESULT__://p' "$outfile")
        case "$result" in
            pass) PASS=$((PASS+1)) ;;
            fail) FAIL=$((FAIL+1)) ;;
            skip) SKIP=$((SKIP+1)) ;;
        esac
        sed '1d' "$outfile"
    done
}

if [ "$SOLO_MODE" -eq 0 ]; then
    echo "labby health-check  ${D}($ENV_FILE)${N}"
    echo
fi

# ── Servarr stack ─────────────────────────────────────────────────────────────
launch_probe radarr   "${RADARR_URL:-}/api/v3/system/status"     -H "X-Api-Key: ${RADARR_API_KEY:-}"
launch_probe sonarr   "${SONARR_URL:-}/api/v3/system/status"     -H "X-Api-Key: ${SONARR_API_KEY:-}"
launch_probe prowlarr "${PROWLARR_URL:-}/api/v1/system/status"   -H "X-Api-Key: ${PROWLARR_API_KEY:-}"

# ── Media ─────────────────────────────────────────────────────────────────────
launch_probe plex      "${PLEX_URL:-}/identity"                  -H "X-Plex-Token: ${PLEX_TOKEN:-}" -H "Accept: application/json"
launch_probe tautulli "${TAUTULLI_URL:-}/api/v2" -G \
    --data-urlencode "apikey=${TAUTULLI_API_KEY:-}" \
    --data-urlencode "cmd=status"

# ── Downloaders ───────────────────────────────────────────────────────────────
launch_probe sabnzbd     "${SABNZBD_URL:-}/api?mode=version&output=json&apikey=${SABNZBD_API_KEY:-}"
launch_probe qbittorrent "${QBITTORRENT_URL:-}/api/v2/auth/login" \
    --data-urlencode "username=${QBITTORRENT_USERNAME:-}" \
    --data-urlencode "password=${QBITTORRENT_PASSWORD:-}" \
    -H "Referer: ${QBITTORRENT_URL:-}"

# ── Network ───────────────────────────────────────────────────────────────────
launch_probe tailscale "${TAILSCALE_URL:-}/api/v2/tailnet/${TAILSCALE_TAILNET:--}/devices" \
    -H "Authorization: Bearer ${TAILSCALE_API_KEY:-}"
launch_probe unifi     "${UNIFI_URL:-}/proxy/network/integration/v1/sites" \
    -H "X-API-KEY: ${UNIFI_API_KEY:-}" -H "Accept: application/json"

# ── Knowledge / notes ─────────────────────────────────────────────────────────
launch_probe linkding  "${LINKDING_URL:-}/api/bookmarks/?limit=1" \
    -H "Authorization: Token ${LINKDING_TOKEN:-}"
launch_probe memos     "${MEMOS_URL:-}/api/v1/workspace/profile" \
    -H "Authorization: Bearer ${MEMOS_TOKEN:-}"
launch_probe bytestash "${BYTESTASH_URL:-}/api/auth/config" \
    -H "Authorization: Bearer ${BYTESTASH_TOKEN:-}"

# ── Infrastructure ────────────────────────────────────────────────────────────
launch_probe arcane    "${ARCANE_URL:-}/api/health" \
    -H "Authorization: Bearer ${ARCANE_API_KEY:-}"
launch_probe unraid    "${UNRAID_URL:-}" \
    -X POST \
    -H "x-api-key: ${UNRAID_API_KEY:-}" \
    -H "Content-Type: application/json" \
    -d '{"query":"{ info { os { uptime } } }"}'

# Multi-instance unraid: only iterate UNRAID_<LABEL>_URL pairs DEFINED IN .env
# (avoids false positives from inherited shell env like UNRAID_MCP_URL)
while IFS='=' read -r var _; do
    label="${var#UNRAID_}"; label="${label%_URL}"
    url_var="UNRAID_${label}_URL"
    key_var="UNRAID_${label}_API_KEY"
    launch_probe "unraid:${label,,}" "${!url_var:-}" \
        -X POST \
        -H "x-api-key: ${!key_var:-}" \
        -H "Content-Type: application/json" \
        -d '{"query":"{ info { os { uptime } } }"}'
done < <(grep -E '^UNRAID_[A-Z0-9]+_URL=' "$ENV_FILE" || true)

collect_results

if [ "$SOLO_MODE" -eq 0 ]; then
    echo
    printf "${G}%d ok${N}  ${R}%d fail${N}  ${Y}%d skip${N}\n" "$PASS" "$FAIL" "$SKIP"
fi
[ $FAIL -eq 0 ]
